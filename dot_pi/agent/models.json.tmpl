{{- /* Profile-based pi agent models configuration */ -}}
{{- /* Work profile: Datadog AI Gateway models only */ -}}
{{- /* Personal profile: OpenRouter models only */ -}}
{{- if eq .profile "work" -}}
{
  "providers": {
    "datadog-ai-gateway": {
      "baseUrl": "https://ai-gateway.us1.staging.dog/v1",
      "api": "openai-completions",
      "apiKey": "!ddtool auth token rapid-ai-platform --datacenter us1.staging.dog",
      "headers": {
        "source": "aip-dev",
        "org-id": "2"
      },
      "models": [
        {
          "id": "openai/gpt-5.5",
          "name": "GPT-5.5 (OpenAI)",
          "api": "openai-responses",
          "reasoning": true
        },
        {
          "id": "google/gemini-3.1-pro-preview",
          "name": "Gemini 3.1 Pro Preview (Google)",
          "reasoning": true
        },
        {
          "id": "google/gemini-3-flash-preview",
          "name": "Gemini 3 Flash Preview (Google)",
          "reasoning": true
        },
        {
          "id": "openai/gpt-5.3-codex",
          "name": "GPT-5.3 Codex (OpenAI)",
          "api": "openai-responses",
          "reasoning": true
        }
      ]
    },
    "datadog-ai-gateway-anthropic": {
      "baseUrl": "https://ai-gateway.us1.staging.dog",
      "api": "anthropic-messages",
      "apiKey": "!ddtool auth token rapid-ai-platform --datacenter us1.staging.dog",
      "authHeader": true,
      "headers": {
        "source": "aip-dev",
        "org-id": "2"
      },
      "models": [
        {
          "id": "anthropic/claude-haiku-4-5-20251001",
          "name": "Claude Haiku 4.5 (Anthropic)",
          "reasoning": true
        },
        {
          "id": "anthropic/claude-sonnet-4-6",
          "name": "Claude Sonnet 4.6 (Anthropic)",
          "reasoning": true
        },
        {
          "id": "anthropic/claude-opus-4-7",
          "name": "Claude Opus 4.7 (Anthropic)",
          "reasoning": true
        }
      ]
    }
  }
}
{{- else -}}
{
  "providers": {
    "openrouter": {
      "baseUrl": "https://openrouter.ai/api/v1",
      "api": "openai-completions",
      "apiKey": "{{ onepasswordRead "op://Private/OpenRouter/openrouter-api-key" }}",
      "models": [
        {
          "id": "deepseek/deepseek-v3.2",
          "name": "DeepSeek V3.2",
          "reasoning": true
        },
        {
          "id": "deepseek/deepseek-r1",
          "name": "DeepSeek R1",
          "reasoning": true
        },
        {
          "id": "anthropic/claude-3.7-sonnet",
          "name": "Claude 3.7 Sonnet",
          "reasoning": true
        },
        {
          "id": "anthropic/claude-3.5-haiku",
          "name": "Claude 3.5 Haiku",
          "reasoning": true
        },
        {
          "id": "openai/o3-mini-high",
          "name": "O3 Mini High",
          "reasoning": true
        },
        {
          "id": "openai/gpt-4o-mini",
          "name": "GPT-4o Mini",
          "reasoning": false
        }
      ]
    }
  }
}
{{- end }}
