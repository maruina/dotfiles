import type { ExtensionAPI } from "@mariozechner/pi-coding-agent";
import { Type } from "typebox";
import { StringEnum } from "@mariozechner/pi-ai";
{{- if eq .profile "work" }}
import { spawn } from "node:child_process";
import { mkdtemp, readFile, rm } from "node:fs/promises";
import { tmpdir } from "node:os";
import { join } from "node:path";
{{- end }}

function getApiKey(): string {
  const key = process.env.TAVILY_API_KEY;
  if (!key) throw new Error("TAVILY_API_KEY environment variable is not set");
  return key;
}
{{ if eq .profile "work" }}
const TOOL_NAME = "codex";
const TOOL_LABEL = "Codex Web Search";
const TOOL_DESCRIPTION =
  "Codex-backed web search and content extraction. Use for current events, documentation lookups, and research tasks that require live web data.";
const TOOL_PROMPT_SNIPPET = "Search the web, extract content from URLs, or conduct deep research via Codex";
const DEFAULT_CODEX_MODEL = "gpt-5.4-mini";
const DEFAULT_CODEX_REASONING_EFFORT = "low";

interface WebSearchParams {
  capability: "search" | "extract" | "crawl" | "map" | "research";
  query?: string;
  urls?: string[];
}

function buildCodexPrompt(params: WebSearchParams): string | null {
  switch (params.capability) {
    case "search":
      if (!params.query) return null;
      return `Search the web for the following query and return a concise answer with source URLs.\n\nQuery: ${params.query}`;
    case "research":
      if (!params.query) return null;
      return `Do deep web research for the following query. Return a thorough answer with source URLs.\n\nQuery: ${params.query}`;
    case "extract":
      if (!params.urls?.length) return null;
      return `Fetch and summarize the content at these URLs. Include key facts and source URLs.\n\nURLs:\n${params.urls.join("\n")}`;
    case "crawl":
      if (!params.urls?.length) return null;
      return `Crawl from these seed URLs and summarize the relevant linked content. Include source URLs.\n\nSeed URLs:\n${params.urls.join("\n")}`;
    case "map":
      if (!params.urls?.length) return null;
      return `Discover and summarize the URL structure for these sites. Include discovered important URLs.\n\nURLs:\n${params.urls.join("\n")}`;
  }
}

async function runCodex(params: WebSearchParams, signal: AbortSignal, cwd: string) {
  const prompt = buildCodexPrompt(params);
  if (!prompt) {
    throw new Error(`Missing required input for codex ${params.capability}`);
  }

  const outputDir = await mkdtemp(join(tmpdir(), "pi-codex-web-search-"));
  const outputPath = join(outputDir, "output.txt");

  try {
    const args = [
      "--search",
      "exec",
      "-m",
      DEFAULT_CODEX_MODEL,
      "-c",
      `model_reasoning_effort=${DEFAULT_CODEX_REASONING_EFFORT}`,
      "--output-last-message",
      outputPath,
      "--ephemeral",
      "--color",
      "never",
      "--cd",
      cwd,
      prompt,
    ];

    await new Promise<void>((resolve, reject) => {
      const child = spawn("codex", args, {
        cwd,
        env: process.env,
        signal,
        stdio: ["ignore", "pipe", "pipe"],
      });

      let stderr = "";
      child.stderr.on("data", (chunk) => {
        stderr += chunk.toString();
      });
      child.on("error", reject);
      child.on("close", (code) => {
        if (code === 0) resolve();
        else reject(new Error(`codex failed (${code}): ${stderr.trim()}`));
      });
    });

    const text = await readFile(outputPath, "utf8");
    return {
      content: [{ type: "text" as const, text }],
      details: {
        provider: "codex",
        model: DEFAULT_CODEX_MODEL,
        reasoningEffort: DEFAULT_CODEX_REASONING_EFFORT,
        capability: params.capability,
        query: params.query,
        urls: params.urls,
      },
    };
  } finally {
    await rm(outputDir, { recursive: true, force: true });
  }
}
{{ end }}
export default function (pi: ExtensionAPI) {
  pi.registerTool({
{{ if eq .profile "work" }}    name: TOOL_NAME,
    label: TOOL_LABEL,
    description: TOOL_DESCRIPTION,
    promptSnippet: TOOL_PROMPT_SNIPPET,
{{ else }}    name: "tavily_api",
    label: "Tavily Web Search",
    description:
      "Tavily AI web search and content extraction. Use for current events, documentation lookups, and research tasks that require live web data.",
    promptSnippet: "Search the web, extract content from URLs, or conduct deep research via Tavily",
{{ end }}
    parameters: Type.Object({
      capability: StringEnum(["search", "extract", "crawl", "map", "research"] as const, {
        description:
          "search: keyword/semantic web search. extract: fetch and parse specific URLs. crawl: follow links from seed URLs. map: discover URL structure. research: deep multi-step search.",
      }),
      query: Type.Optional(
        Type.String({ description: "Search query. Required for 'search' and 'research'." })
      ),
      urls: Type.Optional(
        Type.Array(Type.String(), {
          description: "Target URLs. Required for 'extract', 'crawl', and 'map'.",
        })
      ),
    }),

    async execute(toolCallId, params, signal, _onUpdate, ctx) {
{{ if eq .profile "work" }}      return runCodex(params, signal, ctx.cwd);
{{ else }}      const apiKey = getApiKey();

      // Tavily uses /search endpoint for both search and research modes
      const endpoint = params.capability === "research" ? "search" : params.capability;

      const body: Record<string, unknown> = { api_key: apiKey };
      if (params.query) body.query = params.query;
      if (params.urls) body.urls = params.urls;
      if (params.capability === "research") body.search_depth = "advanced";
      if (params.capability === "search") body.search_depth = "basic";

      const response = await fetch(`https://api.tavily.com/${endpoint}`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(body),
        signal,
      });

      if (!response.ok) {
        const errorText = await response.text();
        throw new Error(`Tavily ${params.capability} failed (${response.status}): ${errorText}`);
      }

      const data = await response.json();
      return {
        content: [{ type: "text" as const, text: JSON.stringify(data, null, 2) }],
        details: { capability: params.capability, query: params.query, urls: params.urls },
      };
{{ end }}    },
  });
}
