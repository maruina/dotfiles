  "model": "opusplan",
  "hooks": {
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "prompt",
            "prompt": "Context is about to be compacted. Before it happens, write a concise session scratchpad to ~/.claude/session-scratchpad.md capturing: 1) What project/workstream we worked on 2) Key outcomes (PRs created/merged, tickets, dashboards, notebooks) with URLs 3) Any unfinished work or next steps 4) Jira ticket IDs involved. Keep it brief — bullet points only. This file will be read by /end-of-session after compaction to reconstruct context."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/matteo.ruina/.claude/hooks/rtk-rewrite.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "npx -y ccstatusline@latest",
    "padding": 0
  },
