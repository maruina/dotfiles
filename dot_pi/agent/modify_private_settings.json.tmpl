#!/bin/sh
# Chezmoi owns stable pi settings only. Pi owns runtime fields such as
# lastChangelogVersion, defaultProvider, defaultModel, and defaultThinkingLevel.
set -eu

input=$(cat)
if [ -z "$input" ]; then
  input='{}'
fi

printf '%s\n' "$input" | jq '
{{- if eq .profile "work" }}
  .skills = [
    "/Users/matteo.ruina/dd/claude-marketplace/compute/skills",
    "/Users/matteo.ruina/dd/claude-marketplace/compute-support/skills",
    "/Users/matteo.ruina/dd/claude-marketplace/dd/skills/conductor"
  ] |
  .packages = [
    "../../go/src/github.com/DataDog/datadog-pi-packages/packages/refresh-models",
    "../../go/src/github.com/DataDog/datadog-pi-packages/packages/confluence-adf"
  ] |
{{- end }}
{{- if eq .profile "personal" }}
  .skills = [
    "/Users/ruio/src/github.com/kepano/obsidian-skills/skills/obsidian-markdown/",
    "/Users/ruio/src/github.com/kepano/obsidian-skills/skills/obsidian-cli/",
    "/Users/ruio/src/github.com/kepano/obsidian-skills/skills/obsidian-bases/",
    "{{ .chezmoi.sourceDir }}/dot_pi/agent/exact_skills_personal"
  ] |
{{- end }}
  del(.extensions.files) |
  .extensionSettings.files.diffEditor = "zed" |
  .extensionSettings.files.externalEditor = "zed" |
  .theme = "catppuccin-frappe" |
  .markdown.codeBlockIndent = ""
'
